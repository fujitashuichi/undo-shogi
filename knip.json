{
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        "pino-pretty",
        "prettier"
      ]
    },
    "apps/frontend": {
      "ignore": [
        "**/.next/**"
      ],
      "entry": [
        "src/**/*.{js,ts,jsx,tsx}",
        "src/app/globals.css"
      ],
      "ignoreDependencies": [
        "@packages/*"
      ]
    },
    "apps/backend": {
      "ignore": [
        "**/dist/**"
      ],
      "ignoreDependencies": [
        "ws", "@types/ws", "@packages/*"
      ]
    },
    "packages/tools": {
      "ignore": [
        "**/dist/**"
      ]
    },
    "packages/shogi": {
      "ignore": [
        "**/dist/**"
      ]
    },
    "packages/ws-messages": {
      "ignore": [
        "**/dist/**"
      ]
    }
  }
}
