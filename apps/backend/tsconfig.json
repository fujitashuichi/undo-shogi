{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    // "module": "nodenext",
    "target": "esnext",
    // "types": [],
    // For nodejs:
    "lib": ["esnext"],
    "types": ["node"],
    // and

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,

    "paths": {
      "@packages/tools": ["../../packages/tools/dist/index.d.ts"],
      "@packages/shogi": ["../../packages/shogi/dist/index.d.ts"],
      "@packages/ws-messages": ["../../packages/ws-messages/dist/index.d.ts"]
    },

    "composite": true
  },

  "references": [
    { "path": "../../packages/tools/" },
    { "path": "../../packages/shogi/" },
    { "path": "../../packages/ws-messages/" }
  ],
  "include": ["./**/*"],
  "exclude": [
    "node_modules", "dist",
    "**/__test__/**", "**/__mock__/**"
  ]
}
